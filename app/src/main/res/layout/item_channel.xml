<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="3dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Badge canal -->
            <TextView
                android:id="@+id/tvChannelNumber"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:background="@drawable/bg_channel_badge" />

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvFrequency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvPrime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="PRIME"
                        android:textSize="8sp"
                        android:textColor="@color/ufpso_red"
                        android:background="@drawable/bg_badge_prime"
                        android:paddingHorizontal="5dp"
                        android:paddingVertical="2dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvRestricted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="RESTRINGIDO"
                        android:textSize="8sp"
                        android:textColor="#9E9E9E"
                        android:background="@drawable/bg_badge_restricted"
                        android:paddingHorizontal="5dp"
                        android:paddingVertical="2dp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="1dp" />

                <ProgressBar
                    android:id="@+id/progressCongestion"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="@color/divider" />

                <TextView
                    android:id="@+id/tvNetworkCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivExpand"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Expandir redes"
                android:tint="@color/text_secondary"
                android:visibility="invisible" />

        </LinearLayout>

        <!-- Redes expandibles -->
        <LinearLayout
            android:id="@+id/layoutNetworks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:paddingTop="8dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>